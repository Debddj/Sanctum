# Sanctum environment configuration
# Copy to .env and fill in your values

# Server
SANCTUM_HOST=0.0.0.0
SANCTUM_PORT=8000
SANCTUM_LOG_LEVEL=info

# Camera
CAMERA_INDEX=0
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Model paths
CLASSIFIER_CHECKPOINT=models/checkpoints/gesture_classifier.pt
TRT_ENGINE_PATH=models/trt_engines/gesture_classifier.engine

# TensorRT
TRT_PRECISION=fp16
TRT_WORKSPACE_MB=1024

# CUDA
CUDA_VISIBLE_DEVICES=0

# Frontend
VITE_WS_URL=ws://localhost:8000/ws
